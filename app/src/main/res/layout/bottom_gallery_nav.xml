<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/bottom_gallery_nav_wrapper"
    android:layout_width="match_parent"
    android:layout_height="64dp"
    android:orientation="vertical">

    <View
        android:id="@+id/bottom_nav_divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:alpha="0.12" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="18dp"
        android:paddingEnd="18dp">

        <ImageButton
            android:id="@+id/bottom_nav_collection"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/bottom_nav_collection"
            android:padding="16dp"
            android:scaleType="center"
            android:src="@drawable/ic_files_vector" />

        <ImageButton
            android:id="@+id/bottom_nav_videos"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/videos"
            android:padding="12dp"
            android:scaleType="center"
            android:src="@drawable/ic_bottom_nav_video" />

        <ImageButton
            android:id="@+id/bottom_nav_favorites"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/bottom_nav_favorites"
            android:padding="16dp"
            android:scaleType="center"
            android:src="@drawable/ic_nav_star_outline" />

        <ImageButton
            android:id="@+id/bottom_nav_albums"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/bottom_nav_albums"
            android:padding="16dp"
            android:scaleType="center"
            android:src="@drawable/ic_folders_vector" />
    </LinearLayout>
</LinearLayout>
